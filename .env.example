# OpenClaw Docker - salin ke .env dan sesuaikan
# cp .env.example .env

# Image resmi (paling ringan yang didukung = bookworm-slim)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Token gateway (kosongkan lalu jalankan onboard; atau generate dengan openclaw-cli)
OPENCLAW_GATEWAY_TOKEN=

# Direktori config & workspace di host (persisten)
OPENCLAW_CONFIG_DIR=./.openclaw
OPENCLAW_WORKSPACE_DIR=./.openclaw/workspace

# Port (default 18789)
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Bind: lan = 0.0.0.0 (akses dari host), loopback = 127.0.0.1 saja
OPENCLAW_GATEWAY_BIND=lan

# Timezone
OPENCLAW_TZ=UTC

# OpenRouter (untuk agent/chat completions). Isi jika "No response from OpenClaw".
# Dapat dari https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# Opsional: session keys untuk provider (isi jika perlu)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=
